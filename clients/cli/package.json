{
  "name": "@vultisig/cli",
  "version": "2.3.1",
  "description": "The self-custody MPC wallet CLI for AI coding agents (Claude Code, Cursor, OpenCode). Natural-language agent mode, 36+ chains, DKLS23 threshold signatures. Seedless.",
  "type": "module",
  "bin": {
    "vsig": "./dist/index.js",
    "vultisig": "./dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node build.mjs",
    "start": "node dist/index.js",
    "dev": "npx tsx src/index.ts",
    "cli": "npx tsx src/index.ts",
    "cli:interactive": "npx tsx src/index.ts --interactive",
    "repl": "npx tsx src/index.ts --interactive",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude 'tests/e2e/**'",
    "test:watch": "vitest --exclude 'tests/e2e/**'",
    "test:e2e": "vitest run tests/e2e/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vultisig",
    "mpc-wallet-cli",
    "ai-agent-cli",
    "claude-code",
    "cursor",
    "opencode",
    "agent-ask",
    "mpc",
    "threshold-signatures",
    "tss",
    "self-custody",
    "seedless",
    "multi-chain-wallet",
    "thorchain-cli",
    "bitcoin-cli",
    "crypto-cli",
    "vsig",
    "wallet-cli",
    "cli",
    "wallet",
    "blockchain",
    "crypto",
    "multi-party-computation"
  ],
  "author": {
    "name": "Vultisig",
    "email": "info@vultisig.com",
    "url": "https://vultisig.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vultisig/vultisig-sdk.git",
    "directory": "clients/cli"
  },
  "bugs": {
    "url": "https://github.com/vultisig/vultisig-sdk/issues"
  },
  "homepage": "https://vultisig.com",
  "dependencies": {
    "@cosmjs/cosmwasm-stargate": "^0.39.0",
    "@cosmjs/encoding": "^0.39.0",
    "@cosmjs/proto-signing": "^0.39.0",
    "@cosmjs/stargate": "^0.39.0",
    "@napi-rs/keyring": "^1.3.0",
    "@noble/hashes": "^2.2.0",
    "@vultisig/client-shared": "workspace:^",
    "@vultisig/core-chain": "workspace:^",
    "@vultisig/rujira": "workspace:^",
    "@vultisig/sdk": "workspace:^",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "ora": "^9.4.0",
    "qrcode-terminal": "^0.12.0",
    "tabtab": "^3.0.2",
    "viem": "^2.52.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.9.2",
    "@types/tabtab": "^3.0.4",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
