# Vultisig Server Configuration (optional overrides)
VULTISIG_SERVER_URL=https://api.vultisig.com/vault
VULTISIG_RELAY_URL=https://api.vultisig.com/router

# Default Settings
DEFAULT_CURRENCY=USD
VAULT_STORAGE_PATH=./vaults

# Vault Password Configuration (optional - use with caution!)
#
# SECURITY WARNING: Storing passwords in .env files is convenient but less secure.
# Only use this for development/testing. For production, use a password manager or prompt entry.
#
# Option 1: Single fallback password (VULTISIG_PASSWORD is an alias during normal unlock)
# VAULT_PASSWORD=mypassword
#
# Option 2: Multiple vaults. JSON is recommended and supports names with spaces.
# VAULT_PASSWORDS='{"Vultisig Cluster #1":"password123","vault-id":"password456"}'
# Legacy space-free keys remain supported: MyVault:password123 WorkVault:password456
#
# Non-interactive auth setup for an encrypted .vult backup:
# VAULT_DECRYPT_PASSWORD=backup-password
# VULTISIG_CREDENTIALS_PASSPHRASE=credentials-file-passphrase
#
# Priority: cache > stored credentials > VAULT_PASSWORDS name > ID > VAULT_PASSWORD > VULTISIG_PASSWORD > prompt

# Network (use testnet for development)
USE_TESTNET=true
