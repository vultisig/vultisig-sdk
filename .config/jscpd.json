{
  "$schema": "https://raw.githubusercontent.com/kucherenko/jscpd/master/schemas/jscpd-schema.json",
  "format": ["typescript", "tsx", "javascript"],
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/dist-electron/**",
    "**/coverage/**",
    "**/docs/api/**",
    "**/*_pb.ts",
    "**/*.d.ts",
    "**/*.snap",
    "**/testdata/**",
    "**/tasks/**",
    "**/CHANGELOG.md",
    "packages/mpc-native/ios/**",
    "../packages/sdk/src/platforms/react-native/overrides/getLifiSwapQuote.ts"
  ],
  "_ignoreReasons": {
    "../packages/sdk/src/platforms/react-native/overrides/getLifiSwapQuote.ts": "React Native intentionally carries an SDK override mirror of the core Lifi quote implementation so Rollup can swap the transport-specific module at bundle time."
  },
  "minLines": 45,
  "minTokens": 120,
  "mode": "strict",
  "reporters": ["console"],
  "threshold": 0
}
