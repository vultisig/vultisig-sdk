{
  "$schema": "https://raw.githubusercontent.com/kucherenko/jscpd/master/schemas/jscpd-schema.json",
  "format": ["typescript", "tsx", "javascript"],
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/dist-electron/**",
    "**/coverage/**",
    "**/docs/api/**",
    "**/*_pb.ts",
    "**/*.d.ts",
    "**/*.snap",
    "**/testdata/**",
    "**/tasks/**",
    "**/CHANGELOG.md",
    "packages/mpc-native/ios/**"
  ],
  "minLines": 45,
  "minTokens": 120,
  "mode": "strict",
  "reporters": ["console"],
  "threshold": 1
}
