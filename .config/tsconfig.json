{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["dom", "dom.iterable", "ESNext", "webworker"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": "..",
    "paths": {
      "@vultisig/core-chain/*": ["packages/core/chain/*"],
      "@vultisig/core-mpc/*": ["packages/core/mpc/*"],
      "@vultisig/core-config": ["packages/core/config/index.ts"],
      "@vultisig/core-config/*": ["packages/core/config/*"],
      "@vultisig/lib-utils/*": ["packages/lib/utils/*"],
      "@vultisig/lib-dkls/*": ["packages/lib/dkls/*"],
      "@vultisig/lib-mldsa/*": ["packages/lib/mldsa/*"],
      "@vultisig/lib-schnorr/*": ["packages/lib/schnorr/*"],
      "@vultisig/sdk": ["packages/sdk/src/index.ts"]
    }
  },
  "references": [],
  "exclude": [
    "../node_modules",
    "../packages/**/node_modules",
    "../packages/**/dist"
  ],
  "include": [
    "../packages/sdk/src/**/*.ts",
    "../packages/sdk/src/**/*.tsx",
    "../packages/core/**/*.ts",
    "../packages/lib/**/*.ts",
    "../packages/rujira/src/**/*.ts"
  ]
}
