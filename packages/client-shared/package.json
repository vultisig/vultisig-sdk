{
  "name": "@vultisig/client-shared",
  "version": "0.2.16",
  "description": "Shared client infrastructure for Vultisig CLI and MCP — auth, config, tool descriptions",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vultisig/vultisig-sdk.git",
    "directory": "packages/client-shared"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepack": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.3.0",
    "@vultisig/sdk": "workspace:^",
    "inquirer": "^14.0.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
