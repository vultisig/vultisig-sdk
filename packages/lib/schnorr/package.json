{
  "name": "@vultisig/lib-schnorr",
  "type": "module",
  "collaborators": [
    "Artem Mironov <artem.mironov@gmail.com>"
  ],
  "version": "0.8.0",
  "license": "SLL",
  "description": "Schnorr WASM bindings for Vultisig",
  "repository": {
    "type": "git",
    "url": "https://github.com/vultisig/vultisig-sdk.git",
    "directory": "packages/lib/schnorr"
  },
  "files": [
    "vs_schnorr_wasm_bg.wasm",
    "vs_schnorr_wasm.js",
    "vs_schnorr_wasm.d.ts",
    "snippets"
  ],
  "main": "vs_schnorr_wasm.js",
  "types": "vs_schnorr_wasm.d.ts",
  "exports": {
    ".": {
      "types": "./vs_schnorr_wasm.d.ts",
      "import": "./vs_schnorr_wasm.js",
      "default": "./vs_schnorr_wasm.js"
    },
    "./vs_schnorr_wasm": {
      "types": "./vs_schnorr_wasm.d.ts",
      "import": "./vs_schnorr_wasm.js",
      "default": "./vs_schnorr_wasm.js"
    }
  },
  "sideEffects": [
    "./snippets/*"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
