{
  "name": "@vultisig/lib-utils",
  "version": "0.9.0",
  "description": "Shared utilities for Vultisig core packages",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vultisig/vultisig-sdk.git",
    "directory": "packages/lib/utils"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "node ../../../scripts/build-shared-packages.mjs",
    "prepack": "node ../../../scripts/build-shared-packages.mjs"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "long": "^5.3.2",
    "viem": "^2.47.4"
  }
}
