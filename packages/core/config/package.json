{
  "name": "@vultisig/core-config",
  "version": "0.9.1",
  "description": "Shared product and API configuration for Vultisig",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vultisig/vultisig-sdk.git",
    "directory": "packages/core/config"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./FiatCurrency": {
      "types": "./dist/FiatCurrency.d.ts",
      "import": "./dist/FiatCurrency.js",
      "default": "./dist/FiatCurrency.js"
    },
    "./package.json": "./package.json",
    "./password": {
      "types": "./dist/password.d.ts",
      "import": "./dist/password.js",
      "default": "./dist/password.js"
    },
    "./vault": {
      "types": "./dist/vault.d.ts",
      "import": "./dist/vault.js",
      "default": "./dist/vault.js"
    }
  },
  "scripts": {
    "build": "node ../../../scripts/build-shared-packages.mjs",
    "prepack": "node ../../../scripts/build-shared-packages.mjs"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
