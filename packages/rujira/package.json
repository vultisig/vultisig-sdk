{
  "name": "@vultisig/rujira",
  "version": "15.0.0",
  "type": "module",
  "description": "Rujira DEX SDK for Vultisig — THORChain-native swaps, limit orders, staking. Built for MPC wallets and AI agents. TypeScript, modular, self-custody.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./swap": {
      "import": "./dist/modules/swap.js",
      "types": "./dist/modules/swap.d.ts"
    },
    "./orderbook": {
      "import": "./dist/modules/orderbook.js",
      "types": "./dist/modules/orderbook.d.ts"
    },
    "./staking": {
      "import": "./dist/modules/staking.js",
      "types": "./dist/modules/staking.d.ts"
    },
    "./ghost": {
      "import": "./dist/modules/ghost.js",
      "types": "./dist/modules/ghost.d.ts"
    },
    "./range": {
      "import": "./dist/modules/range.js",
      "types": "./dist/modules/range.d.ts"
    },
    "./ccl": {
      "import": "./dist/ccl/index.js",
      "types": "./dist/ccl/index.d.ts"
    },
    "./signer": {
      "import": "./dist/signer/vultisig-provider.js",
      "types": "./dist/signer/vultisig-provider.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/format.js",
      "types": "./dist/utils/format.d.ts"
    },
    "./assets": {
      "import": "./dist/assets/index.js",
      "types": "./dist/assets/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist",
    "dev": "tsc -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@cosmjs/cosmwasm-stargate": "^0.38.1",
    "@cosmjs/proto-signing": "^0.38.1",
    "@cosmjs/stargate": "^0.38.1",
    "big.js": "^7.0.1",
    "cosmjs-types": "^0.11.0"
  },
  "devDependencies": {
    "@types/big.js": "^6.2.2",
    "@types/node": "^25.5.0",
    "@vultisig/sdk": "workspace:*",
    "typescript": "^5.9.3",
    "vitest": "^3.0.9"
  },
  "peerDependencies": {
    "@vultisig/sdk": ">=0.20.0"
  },
  "peerDependenciesMeta": {
    "@vultisig/sdk": {
      "optional": true
    }
  },
  "keywords": [
    "vultisig",
    "rujira",
    "thorchain",
    "thorchain-swap",
    "thorchain-dex",
    "limit-order",
    "cross-chain-swap",
    "rune",
    "cosmwasm",
    "cosmos-sdk",
    "defi-sdk",
    "dex-sdk",
    "mpc-wallet-sdk",
    "ai-agent-dex",
    "typescript-dex",
    "defi",
    "dex",
    "swap",
    "cosmos",
    "crypto",
    "wallet"
  ],
  "author": "Vultisig",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vultisig/vultisig-sdk.git",
    "directory": "packages/rujira"
  },
  "bugs": {
    "url": "https://github.com/vultisig/vultisig-sdk/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
